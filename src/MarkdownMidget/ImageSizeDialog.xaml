<Window x:Class="MarkdownMidget.ImageSizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resize Image" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Icon="/Assets/midget-256.png">
    <StackPanel Margin="18" Width="280">
        <TextBlock x:Name="CurrentLabel" Margin="0,0,0,14" Foreground="#555" />
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Width" VerticalAlignment="Center" />
            <TextBox x:Name="WidthBox" Grid.Column="1" Padding="3"
                     PreviewTextInput="DigitsOnly" TextChanged="WidthChanged" />
        </Grid>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Height" VerticalAlignment="Center" />
            <TextBox x:Name="HeightBox" Grid.Column="1" Padding="3"
                     PreviewTextInput="DigitsOnly" TextChanged="HeightChanged" />
        </Grid>
        <TextBlock Text="Aspect ratio is locked to the original." Margin="0,4,0,16"
                   FontSize="11" Foreground="#777" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True" Width="80" Margin="0,0,8,0" Click="Ok_Click" />
            <Button Content="Cancel" IsCancel="True" Width="80" />
        </StackPanel>
    </StackPanel>
</Window>
